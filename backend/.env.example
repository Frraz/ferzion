# =========================
# 🔐 DJANGO
# =========================
DJANGO_SECRET_KEY=django-insecure-change-this-key
DEBUG=False

# Domínios permitidos (se quiser parametrizar depois)
# ALLOWED_HOSTS=ferzion.com.br,www.ferzion.com.br

# =========================
# 📧 EMAIL (SMTP - GMAIL)
# =========================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True

# Seu e-mail (remetente)
EMAIL_HOST_USER=ferzion.dev@gmail.com

# ⚠️ IMPORTANTE:
# Use uma SENHA DE APP do Google (não sua senha normal)
# https://myaccount.google.com/apppasswords
EMAIL_HOST_PASSWORD=coloque_sua_senha_de_app_aqui

# Nome que aparece para o usuário
DEFAULT_FROM_EMAIL="Ferzion <ferzion.dev@gmail.com>"

# =========================
# 🌐 FRONTEND / API (opcional)
# =========================
# BASE_URL=https://ferzion.com.br
